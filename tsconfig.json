{
	"compilerOptions": {
		"target": "es2021",
		"lib": ["es2021", "dom"],
		"module": "commonjs",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"outDir": "dist/src"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
